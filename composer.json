{
    "name": "djalone/kkm-server-classes",
    "description": "PHP classes to create json for kkmServer",
    "type": "library",
    "require": {
        "php": ">=8.1",
        "twig/twig": "^3.23",
        "ext-gd": "*",
        "ext-bcmath": "*",
        "twbs/bootstrap": "5.3.8",
        "symfony/http-foundation": "^8.0",
        "symfony/serializer": "^8.0",
        "symfony/property-access": "^8.0",
        "phpdocumentor/reflection-docblock": "^6.0",
        "symfony/serializer-pack": "^1.3",
        "ramsey/uuid": "^4.9",
        "monolog/monolog": "^3.10",
        "tecnickcom/tc-lib-barcode": "^2.4",
        "phpseclib/bcmath_compat": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "rector/rector": "^2.3",
        "friendsofphp/php-cs-fixer": "^3.94"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Djalone\\KkmServerClasses\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Egor Ermilov",
            "email": "egor.ermilov1992@gmail.com"
        }
    ],
    "scripts": {
        "post-install-cmd": [
            "mkdir -p var",
            "chmod 777 var",
            "mkdir -p var/logs",
            "chmod 777 var/logs"
        ],
        "post-update-cmd": [
            "mkdir -p var",
            "chmod 777 var",
            "mkdir -p var/logs",
            "chmod 777 var/logs"
        ]
    },
    "minimum-stability": "stable"
}
